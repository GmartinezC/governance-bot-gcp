# ============================================================
# Bot Autónomo de Gobierno de Datos en GCP — Variables de entorno
# ============================================================
# Copiar a .env y completar con valores reales.
# NUNCA commitear .env al repositorio.

# --- Proyecto GCP principal (donde corre el bot) ---
GCP_PROJECT_ID=my-governance-project

# --- Región por defecto para Vertex AI y otros servicios ---
GCP_REGION=us-central1

# --- Firestore ---
# Nombre de la base de datos Firestore (usar "(default)" para la base por defecto)
FIRESTORE_DATABASE=(default)

# --- BigQuery ---
# Dataset donde se guardan los resultados de auditoría
BQ_DATASET=governance_bot

# --- Cloud Storage ---
# Bucket donde se almacenan los reportes generados (sin gs://)
GCS_REPORTS_BUCKET=my-governance-reports-bucket

# --- Pub/Sub ---
# Nombre del topic de alertas (solo el nombre, sin projects/...)
PUBSUB_TOPIC_ALERTS=governance-alerts

# --- Vertex AI / Gemini ---
# Modelo de Gemini a usar para el Planner
VERTEX_MODEL=gemini-1.5-pro

# --- Logging ---
# Nivel de log: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# --- Proyectos a auditar ---
# Lista separada por comas de los project IDs de GCP a auditar
TARGET_PROJECTS=project-one,project-two,project-three

# --- Scope de auditoría ---
# Módulos a ejecutar. Opciones: iam, dlp, catalog, lineage, policy, bq, scc, kms
# Usar "full" para ejecutar todos los módulos
AUDIT_SCOPE=full
